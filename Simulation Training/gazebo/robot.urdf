<?xml version="1.0"?>
<robot name="hrnsq">
  <link name="base_link">
    <inertial>
      <mass value="3.0"/>
      <origin xyz="0 0 0"/>
      <inertia ixx="0.08" ixy="0" ixz="0" iyy="0.12" iyz="0" izz="0.16"/>
    </inertial>
    <visual>
      <geometry><box size="0.42 0.22 0.08"/></geometry>
    </visual>
    <collision>
      <geometry><box size="0.42 0.22 0.08"/></geometry>
    </collision>
  </link>
  <link name="front_left_foot"/>
  <joint name="front_left_leg" type="fixed">
    <parent link="base_link"/>
    <child link="front_left_foot"/>
    <origin xyz="0.16 0.12 -0.22"/>
  </joint>
</robot>
